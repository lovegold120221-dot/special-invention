# OpenCode Environment Configuration
#
# Copy this file to .env and adjust as needed.
# All variables are optional — defaults work out of the box.

# ─── Speech-to-Text (Whisper) ──────────────────────────────────────

# Path to the whisper CLI binary (default: "whisper")
# OPENCODE_STT_WHISPER_BIN=whisper

# Whisper model size: tiny, base, small, medium, large (default: "base")
# OPENCODE_STT_WHISPER_MODEL=base

# Language code for STT. Use ISO 639-1 two-letter code (e.g. "en", "fr", "de")
# or "auto" for auto-detection. When "auto", the --language flag is omitted
# since the whisper CLI doesn't accept "auto" as a value. (default: "auto")
# OPENCODE_STT_LANGUAGE=auto

# ─── Text-to-Speech (Voicebox) ────────────────────────────────────

# Voicebox API base URL (default: "http://127.0.0.1:17493")
# VOICEBOX_API_URL=http://127.0.0.1:17493

# Voicebox data directory (models, profiles, generated audio)
# Default: <repo>/voicebox/data
# VOICEBOX_DATA_DIR=./voicebox/data
